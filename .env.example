# Copy this to .env and fill in real values. Read by apps/api, apps/worker, and apps/web
# (Vite only exposes the VITE_-prefixed key) - see each app's src/**/config/env.ts.
# The real .env is gitignored — never commit secrets.

NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:4000
VITE_API_URL=http://localhost:4000

# MongoDB Atlas (or any MongoDB) connection string. Percent-encode special characters in the
# username/password (e.g. literal "@" -> "%40") or the URI will fail to parse correctly.
# Database name must be "sowetostays" — other project DBs (e.g. "pannotia") can carry conflicting
# unique indexes (e.g. googleSub_1) on the users collection.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster-host>/sowetostays?appName=Cluster0

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# From Google Cloud Console > APIs & Services > Credentials (OAuth client ID, type "Web
# application"). GIS credential flow: only the client id is needed (no secret, no callback
# URL), but the client's "Authorized JavaScript origins" must include every origin the web
# app is served from - http://localhost:5173 for dev, https://<DOMAIN> for the droplet -
# or the Google button fails with a 401/origin_mismatch. Set both vars to the same value
# (api verifies the token's audience; web bakes it into the button at build time).
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

REDIS_URL=redis://localhost:6379

# Deploy-only (docker-compose on the droplet - see DEPLOY.md). DOMAIN is the public
# hostname Caddy terminates HTTPS for; <droplet-ip-with-dashes>.sslip.io works with zero
# DNS setup. REDIS_PASSWORD protects the compose-network redis (generate like a JWT secret).
DOMAIN=
REDIS_PASSWORD=

# Yoco (developer.yoco.com). Get YOCO_SECRET_KEY from Yoco App > Sales > Payment Gateway -
# starts with sk_test_ for test mode, sk_live_ for live (no separate mode flag). Mode is
# implied by the key prefix for checkouts, but the webhook secret is tied to whichever key
# registered it — going live means re-registering the webhook with the sk_live_ key.
# Get YOCO_WEBHOOK_SECRET (starts with whsec_) by calling the Checkout API directly - not the
# dashboard UI: POST https://payments.yoco.com/api/webhooks with "Authorization: Bearer
# <YOCO_SECRET_KEY>" and body {"name": "...", "url": "<API_PUBLIC_URL>/api/payments/yoco/notify"}.
# The response's "secret" field is shown only once. Yoco requires HTTPS for webhooks (localhost
# cannot receive them — use the droplet/public URL).
YOCO_SECRET_KEY=
# Optional reference only - checkout is server-side (payment.service.ts); not read by the app today.
YOCO_PUBLIC_KEY=
YOCO_WEBHOOK_SECRET=

# Transactional email via SMTP - read by apps/worker only (booking-confirmed, reminders, etc.).
# Without SMTP_USER/SMTP_PASS, the worker logs emails instead of sending them - see mailer.ts.
#
# Gmail (free, ~500 emails/day): enable 2-Step Verification, then create an App Password at
# https://myaccount.google.com/apppasswords — use that 16-char value as SMTP_PASS.
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=yourname@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx
#   EMAIL_FROM=Soweto Stays <yourname@gmail.com>
#
# Brevo free tier (300 emails/day, no credit card): smtp-relay.brevo.com:587.
# SMTP_USER = Brevo login email; SMTP_PASS = SMTP key (Brevo dashboard -> SMTP & API -> SMTP);
# EMAIL_FROM = a sender address verified via the confirmation link Brevo emails you.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Soweto Stays <no-reply@sowetostays.local>

UPLOAD_DIR=uploads
