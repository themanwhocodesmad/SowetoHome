# Reference Nginx config for the VPS itself (outside Docker) - fronts both the `web` and
# `api` containers on one real domain and terminates TLS. NOT wired into docker-compose.yml
# because it needs your actual domain name and a certbot-issued certificate, which only
# exist once you've pointed DNS at the VPS. See claude_plan.md §11 and README.md for the
# full deploy steps this fits into.
#
# Replace sowetostays.example with your real domain, then run certbot against this file.

server {
    listen 80;
    server_name sowetostays.example www.sowetostays.example;

    # Certbot's --nginx plugin rewrites this block to redirect to 443 once a cert exists.
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name sowetostays.example www.sowetostays.example;

    ssl_certificate     /etc/letsencrypt/live/sowetostays.example/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/sowetostays.example/privkey.pem;

    # PayFast's ITN webhook (see payment.service.ts) needs this path reachable from the
    # public internet - make sure API_PUBLIC_URL in .env matches this domain.
    location /api/ {
        proxy_pass http://127.0.0.1:4000/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /uploads/ {
        proxy_pass http://127.0.0.1:4000/uploads/;
    }

    location / {
        proxy_pass http://127.0.0.1:5173/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
